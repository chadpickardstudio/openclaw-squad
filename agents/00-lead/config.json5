// openclaw.json agent entry for Lead (CEO) — IntegrateAI Advisors
// Copy this into the "agents.list" array in ~/.openclaw/openclaw.json
{
  "id": "lead",
  "default": true,
  "name": "Lead (CEO / Chief of Staff)",
  "workspace": "~/.openclaw/workspace-lead",
  "agentDir": "~/.openclaw/agents/lead/agent",
  "model": {
    "primary": "anthropic/claude-opus-4-6",
    "fallbacks": ["anthropic/claude-sonnet-4-6"],
  },
  "tools": {
    "profile": "full",
    "allow": [
      "read", "write", "edit",
      "sessions_spawn", "sessions_send", "sessions_list",
      "memory_search",
      "fs_read", "fs_write",
    ],
    "deny": ["exec", "sudo"],
  },
  "sandbox": {
    "mode": "all",
    "workspaceAccess": "rw",
    "networkAccess": "restricted",
  },
  "compaction": {
    "mode": "safeguard",
    "reserveTokensFloor": 20000,
    "memoryFlush": {
      "enabled": true,
      "softThresholdTokens": 4000,
    },
  },
  "heartbeat": {
    "every": "30m",
    "max_turns": 3,
    "enabled": true,
  },
}
