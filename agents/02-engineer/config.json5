// openclaw.json agent entry for Engineer
{
  "id": "engineer",
  "name": "Engineer (CTO)",
  "workspace": "~/.openclaw/workspace-engineer",
  "agentDir": "~/.openclaw/agents/engineer/agent",
  "model": {
    "primary": "anthropic/claude-sonnet-4-6",
    "fallbacks": ["anthropic/claude-haiku-4-5"],
  },
  "tools": {
    "profile": "coding",
    "allow": [
      "read", "write", "edit",
      "sessions_send",
      "memory_search",
      "browser",
    ],
    "deny": ["exec", "sudo", "tools.elevated"],
  },
  "sandbox": {
    "mode": "all",
    "workspaceAccess": "rw",
    "networkAccess": "restricted",
  },
  "compaction": {
    "mode": "safeguard",
    "reserveTokensFloor": 20000,
    "memoryFlush": {
      "enabled": true,
      "softThresholdTokens": 4000,
    },
  },
  "heartbeat": {
    "every": "2h",
    "max_turns": 2,
    "enabled": true,
  },
}
